# ML Service Environment Variables

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false

# Service Port
PORT=5000

# Optional: Backend connection (if ML service needs to connect back)
# BACKEND_URL=https://your-backend-url.vercel.app

# Optional: Database URL (if using)
# DATABASE_URL=postgres://user:pass@host/db

# Optional: API Key for securing ML endpoints
# API_KEY=your-secret-key-here
