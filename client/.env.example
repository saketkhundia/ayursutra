# Frontend Environment Variables

# ========================================
# API Configuration
# ========================================
# Leave VITE_API_URL empty in .env for local dev (uses Vite proxy → localhost:3001)
# Set VITE_API_URL in .env.production for deployed builds:
#   VITE_API_URL=https://ayus-one.vercel.app/api
# ========================================
# VITE_API_URL=

# ========================================
# Firebase Web SDK (required for Google OAuth)
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
# ========================================
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
