# ========================================
# AyurSutra Backend Environment Variables
# For Vercel Deployment
# ========================================

# Server Configuration
NODE_ENV=production
PORT=3001

# ========================================
# Firebase Configuration (REQUIRED)
# Get from Firebase Console → Project Settings
# Download service account key JSON and extract values
# ========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ========================================
# JWT & Authentication (REQUIRED)
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters for production
# ========================================
JWT_SECRET=generate-a-secure-random-32-char-minimum-secret-here
JWT_REFRESH_SECRET=generate-a-secure-random-32-char-minimum-secret-here
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ========================================
# Email Configuration (Optional - for notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@ayursutra.com

# ========================================
# ML Service (REQUIRED if using AI features)
# For Vercel deployment, use Railway or Render URL
# Example: https://ayursutra-ml.railway.app
# ========================================
ML_SERVICE_URL=https://your-ml-service-url.railway.app

# ========================================
# CORS Configuration (REQUIRED for production)
# Add your production frontend URL
# ========================================
ALLOWED_ORIGINS=https://ayursu.vercel.app

# ========================================
# Logging
# ========================================
LOG_LEVEL=info

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Security (REQUIRED for production)
# ========================================
HTTPS_REDIRECT=true
